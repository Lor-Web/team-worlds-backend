NODE_ENV=production
PORT=3000
DATABASE_URL="postgresql://teamworlds:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/teamworlds"
CORS_ORIGIN=https://team-worlds.ru

JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_SECRET_32_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

HOST_GRACE_PERIOD_SECONDS=60

