{
  "openapi": "3.0.3",
  "info": {
    "title": "Team Worlds API",
    "version": "0.1.0",
    "description": "REST API платформы Team Worlds — совместные игры с друзьями в «Мирах».\n\n**Authentication**\n- Access token (JWT) — в ответе login/register, передавать в `Authorization: Bearer ...`\n- Refresh token — httpOnly cookie, только на `/auth/*`; на фронте: `credentials: include`\n\n**Автовход на фронте**: `POST /auth/refresh` при старте приложения → `GET /users/me`"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Локальная разработка"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Регистрация, вход, refresh, выход"
    },
    {
      "name": "Users",
      "description": "Профиль и настройки"
    },
    {
      "name": "Worlds",
      "description": "Создание, вступление, список и участники"
    },
    {
      "name": "System",
      "description": "Служебные эндпоинты"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Access token из ответа login/register. Передавать в заголовке: Authorization: Bearer <token>"
      },
      "refreshCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "refreshToken",
        "description": "HttpOnly cookie с refresh-токеном. Path: /auth. На фронте: credentials: 'include'"
      }
    },
    "schemas": {
      "PublicUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID пользователя"
          },
          "username": {
            "type": "string",
            "description": "Имя пользователя"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email"
          },
          "avatar": {
            "type": "string",
            "nullable": true,
            "description": "URL аватара"
          },
          "siteRole": {
            "type": "string",
            "enum": [
              "USER",
              "ADMIN"
            ],
            "description": "Роль пользователя на сайте"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата регистрации (ISO 8601)"
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "avatar",
          "siteRole",
          "createdAt"
        ]
      },
      "AuthTokensResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token (~15 мин). Хранить в памяти на фронте."
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "accessToken",
          "user"
        ],
        "description": "Успешная аутентификация. Refresh token устанавливается в httpOnly cookie."
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "VALIDATION_ERROR"
                ],
                "description": "Код ошибки валидации"
              },
              "message": {
                "type": "string",
                "description": "Сообщение",
                "example": "Validation failed"
              },
              "details": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "description": "Ошибки по полям"
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Код ошибки",
                "example": "INVALID_CREDENTIALS"
              },
              "message": {
                "type": "string",
                "description": "Текст ошибки"
              }
            },
            "required": [
              "code",
              "message"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "RegisterBody": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32,
            "pattern": "^[a-zA-Z0-9_]+$",
            "description": "Имя пользователя",
            "example": "alice"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "format": "password",
            "description": "Пароль"
          }
        },
        "required": [
          "username",
          "email",
          "password"
        ],
        "description": "Данные для регистрации"
      },
      "LoginBody": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "format": "password",
            "description": "Пароль"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "description": "Данные для входа"
      },
      "RefreshAccessResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Новый JWT access token"
          }
        },
        "required": [
          "accessToken"
        ]
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "user"
        ]
      },
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "degraded"
            ],
            "description": "Состояние сервиса"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Время проверки (ISO 8601)"
          },
          "database": {
            "type": "string",
            "enum": [
              "connected",
              "disconnected"
            ],
            "description": "Подключение к базе данных"
          }
        },
        "required": [
          "status",
          "timestamp",
          "database"
        ]
      },
      "WorldSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID мира"
          },
          "name": {
            "type": "string",
            "description": "Название"
          },
          "inviteCode": {
            "type": "string",
            "description": "Код приглашения"
          },
          "tier": {
            "type": "string",
            "enum": [
              "STANDARD",
              "EXTENDED",
              "VIP"
            ],
            "description": "Статус мира",
            "example": "STANDARD"
          },
          "maxMembers": {
            "type": "integer",
            "description": "Максимум участников для текущего статуса"
          },
          "ownerId": {
            "type": "string",
            "description": "ID владельца"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата создания"
          },
          "myRole": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ],
            "description": "Ваша роль в мире"
          },
          "memberCount": {
            "type": "integer",
            "description": "Текущее число участников"
          }
        },
        "required": [
          "id",
          "name",
          "inviteCode",
          "tier",
          "maxMembers",
          "ownerId",
          "createdAt",
          "myRole",
          "memberCount"
        ]
      },
      "WorldResponse": {
        "type": "object",
        "properties": {
          "world": {
            "$ref": "#/components/schemas/WorldSummary"
          }
        },
        "required": [
          "world"
        ]
      },
      "CreateWorldBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 64,
            "description": "Название мира",
            "example": "Наша компания"
          }
        },
        "required": [
          "name"
        ]
      },
      "JoinWorldResponse": {
        "type": "object",
        "properties": {
          "world": {
            "$ref": "#/components/schemas/WorldSummary"
          }
        },
        "required": [
          "world"
        ]
      },
      "JoinWorldBody": {
        "type": "object",
        "properties": {
          "inviteCode": {
            "type": "string",
            "minLength": 6,
            "maxLength": 12,
            "pattern": "^[A-Z0-9]+$",
            "description": "Код приглашения в мир",
            "example": "AB12CD34"
          }
        },
        "required": [
          "inviteCode"
        ]
      },
      "WorldListResponse": {
        "type": "object",
        "properties": {
          "worlds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorldSummary"
            }
          }
        },
        "required": [
          "worlds"
        ]
      },
      "WorldMember": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "description": "ID пользователя"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ],
            "description": "Роль участника в мире"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "world.members.manage",
                "world.settings.manage",
                "world.games.host"
              ],
              "description": "Дополнительное право участника (owner имеет все права)"
            },
            "description": "Дополнительные права"
          },
          "joinedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата вступления"
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          }
        },
        "required": [
          "userId",
          "role",
          "permissions",
          "joinedAt",
          "user"
        ]
      },
      "WorldDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "inviteCode": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "enum": [
              "STANDARD",
              "EXTENDED",
              "VIP"
            ],
            "description": "Статус мира: STANDARD — обычный, EXTENDED — расширенный, VIP — VIP",
            "example": "STANDARD"
          },
          "maxMembers": {
            "type": "integer"
          },
          "ownerId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "myRole": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ],
            "description": "Роль участника в мире"
          },
          "memberCount": {
            "type": "integer"
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorldMember"
            }
          }
        },
        "required": [
          "id",
          "name",
          "inviteCode",
          "tier",
          "maxMembers",
          "ownerId",
          "createdAt",
          "myRole",
          "memberCount",
          "members"
        ]
      },
      "WorldDetailResponse": {
        "type": "object",
        "properties": {
          "world": {
            "$ref": "#/components/schemas/WorldDetail"
          }
        },
        "required": [
          "world"
        ]
      },
      "UpdateWorldBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 64,
            "description": "Новое название мира",
            "example": "Новое название"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Регистрация",
        "description": "Создаёт пользователя, возвращает access token и профиль. Refresh token записывается в httpOnly cookie (нужен credentials: include на фронте).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Пользователь создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokensResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "409": {
            "description": "Email или имя пользователя уже заняты",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Вход",
        "description": "Проверяет email и пароль. Возвращает access token и профиль. Refresh token — в httpOnly cookie.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешный вход",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthTokensResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Неверный email или пароль",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Обновить access token",
        "description": "Использует refresh token из cookie. Выполняет rotation: старый refresh удаляется, выдаётся новый в cookie. Вызывать при загрузке приложения для «тихого» входа.",
        "security": [
          {
            "refreshCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Новый access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshAccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Cookie отсутствует, истёк или недействителен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Выход",
        "description": "Отзывает refresh token в БД и удаляет cookie. Тело ответа пустое.",
        "security": [
          {
            "refreshCookie": []
          }
        ],
        "responses": {
          "204": {
            "description": "Успешный выход"
          },
          "401": {
            "description": "Недействительный refresh token (опционально)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Текущий пользователь",
        "description": "Возвращает профиль авторизованного пользователя по access token.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Профиль пользователя",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Токен отсутствует, истёк или недействителен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Пользователь не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Проверка состояния",
        "description": "Health check API и подключения к базе данных.",
        "responses": {
          "200": {
            "description": "Сервис работает",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          },
          "503": {
            "description": "Сервис недоступен (проблема с БД)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            }
          }
        }
      }
    },
    "/worlds": {
      "post": {
        "tags": [
          "Worlds"
        ],
        "summary": "Создать мир",
        "description": "Создаёт новый мир. Вы становитесь владельцем (owner). Генерируется уникальный код приглашения.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWorldBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Мир создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorldResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Worlds"
        ],
        "summary": "Мои миры",
        "description": "Список миров, в которых вы участник.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Список миров",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorldListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/worlds/join": {
      "post": {
        "tags": [
          "Worlds"
        ],
        "summary": "Вступить в мир",
        "description": "Вступление по коду приглашения. Если вы уже участник — возвращает мир без ошибки.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinWorldBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешное вступление или вы уже в мире",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JoinWorldResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "403": {
            "description": "Достигнут лимит участников для статуса мира",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "Код приглашения не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/worlds/{worldId}": {
      "get": {
        "tags": [
          "Worlds"
        ],
        "summary": "Детали мира",
        "description": "Информация о мире и список участников. Доступно только участникам мира.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "cuid"
            },
            "required": true,
            "name": "worldId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Детали мира",
            "content": {
              "application/json": {
                "schema": {
